{
  "name": "studyforge-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:portal": "npm --workspace @studyforge/portal-web run dev",
    "dev:knowledge": "npm --workspace @studyforge/knowledge-web run dev",
    "build:portal": "npm --workspace @studyforge/portal-web run build",
    "build:knowledge": "npm --workspace @studyforge/knowledge-web run build",
    "build": "npm run build:portal && npm run build:knowledge",
    "typecheck": "npm --workspace @studyforge/portal-web run typecheck && npm --workspace @studyforge/knowledge-web run typecheck"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
